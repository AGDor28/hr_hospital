<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_hospital_disease_report_wizard_view_form" model="ir.ui.view">
        <field name="name">hr.hospital.disease.report.wizard.form</field>
        <field name="model">hr.hospital.disease.report.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group>
                        <field name="doctor_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        <field name="disease_ids" widget="many2many_tags" options="{'no_create': True}"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate_report" string="Generate Report" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_disease_report_wizard" model="ir.actions.act_window">
        <field name="name">Disease Report by Month</field>
        <field name="res_model">hr.hospital.disease.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="action_disease_report_doctor_binding" model="ir.actions.act_window">
        <field name="name">Disease Report by Month</field>
        <field name="res_model">hr.hospital.disease.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_hr_hospital_doctor"/>
        <field name="binding_view_types">list,form</field>
    </record>
</odoo>