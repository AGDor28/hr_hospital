<odoo>
    <record id="hr_hospital_mass_reassign_doctor_wizard_form" model="ir.ui.view">
        <field name="name">hr.hospital.mass.reassign.doctor.wizard.form</field>
        <field name="model">hr.hospital.mass.reassign.doctor.wizard</field>
        <field name="arch" type="xml">
            <form>
                <div class="alert alert-info text-center" role="status">
                    This wizard add possibility to reassign doctor in patient
                </div>
                <group>
                    <field name="new_doctor_id"/>
                    <field name="reassignment_date"/>
                </group>
                <footer>
                    <button string="Reassign doctor" name="reassign_doctor" type="object" class="oe_highlight" data-hotkey="q"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="hr_hospital_mass_reassign_doctor_wizard_action" model="ir.actions.act_window">
        <field name="name">Mass Reassign Doctor</field>
        <field name="res_model">hr.hospital.mass.reassign.doctor.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_hr_hospital_patient"/>
        <field name="binding_view_types">list</field>
    </record>
</odoo>
