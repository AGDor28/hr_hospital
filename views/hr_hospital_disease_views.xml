<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="hr_hospital_disease_tree" model="ir.ui.view">
            <field name="name">hr.hospital.disease.tree ()</field>
            <field name="model">hr.hospital.disease</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="description"/>
                </list>
            </field>
        </record>

        <record id="hr_hospital_disease_search" model="ir.ui.view">
            <field name="name">hr.hospital.disease.search</field>
            <field name="model">hr.hospital.disease</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>

                    <searchpanel>
                        <field name="parent_id"
                               string="Diseases Hierarchy"
                               icon="fa-folder"
                               hierarchy="1"
                               enable_counters="1"/>
                    </searchpanel>
                </search>
            </field>
        </record>

        <record id="hr_hospital_disease_form" model="ir.ui.view">
            <field name="name">hr.hospital.disease.form ()</field>
            <field name="model">hr.hospital.disease</field>
            <field name="arch" type="xml">
                <form>
                    <header></header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="description"/>
                                <field name="parent_id"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_hr_hospital_disease_window" model="ir.actions.act_window">
            <field name="name">Disease</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">hr.hospital.disease</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="hr_hospital_disease_search"/>
        </record>

        <menuitem id="hr_hospital_menu_item_disease"
                  action="action_hr_hospital_disease_window"
                  parent="hr_hospital_menu_disease"
                  name="Disease" sequence="200"/>
</odoo>