<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="hr_hospital_doctor_tree" model="ir.ui.view">
            <field name="name">hr.hospital.doctor.tree ()</field>
            <field name="model">hr.hospital.doctor</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="specialty"/>
                    <field name="mentor_id"/>
                    <field name="category_id"/>
                    <field name="is_intern"/>
                </list>
            </field>
        </record>

        <record id="hr_hospital_doctor_form" model="ir.ui.view">
            <field name="name">hr.hospital.doctor.form ()</field>
            <field name="model">hr.hospital.doctor</field>
            <field name="arch" type="xml">
                <form>
                    <header></header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="specialty"/>
                                <field name="category_id"/>
                            </group>
                            <group>
                                <field name="is_intern"/>
                                <field name="mentor_id" invisible="not is_intern" required="is_intern" domain="[('is_intern', '=', False)]"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Mentor Info" name="mentor_info" invisible="not is_intern">
                                <group>
                                    <field name="mentor_id"
                                           required="is_intern"
                                           domain="[('is_intern', '=', False), ('id', '!=', id)]"
                                           options="{'no_create': True}"/>
                                    <field name="mentor_specialty"/>
                                </group>
                                <group string="Contact Details">
                                    <field name="mentor_phone"/>
                                    <field name="mentor_email"/>
                                </group>
                            </page>

                            <page string="Interns List" name="interns" invisible="is_intern">
                                <field name="intern_ids" mode="kanban" readonly="1">
                                    <kanban>
                                        <field name="id"/>
                                        <field name="name"/>
                                        <field name="specialty"/>
                                        <templates>
                                            <t t-name="card">
                                                <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                                                    <div class="oe_kanban_details">
                                                        <strong class="o_kanban_record_title">
                                                            <field name="name"/>
                                                        </strong>
                                                        <div class="o_kanban_record_body">
                                                            <span>Specialty: </span>
                                                            <field name="specialty"/>
                                                        </div>
                                                        <div class="o_kanban_record_bottom">
                                                            <div class="oe_kanban_bottom_left">
                                                                <field name="category_id"/>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </t>

                                            <t t-name="kanban-box">
                                                <t t-call="card"/>
                                            </t>
                                        </templates>
                                    </kanban>
                                </field>
                            </page>

                            <page string="Visits History" name="visits">
                                <field name="visit_ids" readonly="1">
                                    <list>
                                        <field name="planned_date"/>
                                        <field name="patient_id"/>
                                        <field name="status"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="hr_hospital_doctor_search" model="ir.ui.view">
            <field name="name">hr.hospital.doctor.search</field>
            <field name="model">hr.hospital.doctor</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" string="Doctor Name"/>

                    <separator/>

                    <filter string="Interns" name="filter_interns" domain="[('is_intern', '=', True)]"/>
                    <filter string="Mentors (Experienced Doctors)" name="filter_mentors" domain="[('is_intern', '=', False)]"/>

                    <separator/>

                    <filter string="Mentor" name="group_by_mentor" context="{'group_by': 'mentor_id'}"/>
                    <filter string="Category" name="group_by_category" context="{'group_by': 'category_id'}"/>
                </search>
            </field>
        </record>

        <record id="hr_hospital_doctor_kanban" model="ir.ui.view">
            <field name="name">hr.hospital.doctor.kanban</field>
            <field name="model">hr.hospital.doctor</field>
            <field name="arch" type="xml">
                <kanban default_group_by="specialty" class="o_kanban_dashboard">
                    <field name="id"/>
                    <field name="name"/>
                    <field name="specialty"/>
                    <field name="is_intern"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click">
                                <div class="oe_kanban_content">
                                    <div class="o_kanban_record_top">
                                        <div class="o_kanban_record_headings">
                                            <strong class="o_kanban_record_title">
                                                <field name="name"/>
                                            </strong>
                                        </div>
                                    </div>

                                    <div class="o_kanban_record_body mt-2">
                                        <span t-if="record.is_intern.raw_value" class="badge rounded-pill text-bg-warning">
                                            Intern
                                        </span>
                                        <div>
                                            <i class="fa fa-stethoscope"/> <field name="specialty"/>
                                        </div>
                                    </div>

                                    <div class="o_kanban_record_bottom mt-3">
                                        <button name="action_create_visit"
                                                type="object"
                                                class="btn btn-primary btn-sm w-100">
                                            <i class="fa fa-calendar-plus-o"/> Quick Visit
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </t>

                        <t t-name="kanban-box">
                            <t t-call="card"/>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="action_hr_hospital_doctor_window" model="ir.actions.act_window">
            <field name="name">Doctor</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">hr.hospital.doctor</field>
            <field name="view_mode">list,kanban,form</field>
            <field name="search_view_id" ref="hr_hospital_doctor_search"/>
        </record>

        <menuitem id="hr_hospital_menu_item_doctor"
                  action="action_hr_hospital_doctor_window"
                  parent="hr_hospital_menu_doctor"
                  name="Doctor" sequence="200"/>

</odoo>