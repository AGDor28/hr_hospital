<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="hr_hospital_doctor_category_tree" model="ir.ui.view">
            <field name="name">hr.hospital.doctor.category.tree ()</field>
            <field name="model">hr.hospital.doctor.category</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="sequence"/>
                </list>
            </field>
        </record>

        <record id="hr_hospital_doctor_category_form" model="ir.ui.view">
            <field name="name">hr.hospital.doctor.category.form ()</field>
            <field name="model">hr.hospital.doctor.category</field>
            <field name="arch" type="xml">
                <form>
                    <header></header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="sequence"/>
                            </group>
                            <group>
                                <field name="doctor_ids"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_hr_hospital_doctor_category_window" model="ir.actions.act_window">
            <field name="name">Doctor category</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">hr.hospital.doctor.category</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="hr_hospital_menu_item_doctor_category"
                  action="action_hr_hospital_doctor_category_window"
                  parent="hr_hospital_menu_doctor"
                  name="Doctor category" sequence="200"/>

</odoo>