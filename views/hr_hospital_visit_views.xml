<odoo>
        <record id="hr_hospital_visit_tree" model="ir.ui.view">
            <field name="name">hr.hospital.visit.tree ()</field>
            <field name="model">hr.hospital.visit</field>
            <field name="arch" type="xml">
                <list>
                    <field name="planned_date"/>
                    <field name="visit_date"/>
                    <field name="doctor_id"/>
                    <field name="patient_id"/>
                    <field name="status"/>
                </list>
            </field>
        </record>

        <record id="hr_hospital_visit_form" model="ir.ui.view">
            <field name="name">hr.hospital.visit.form ()</field>
            <field name="model">hr.hospital.visit</field>
            <field name="arch" type="xml">
                <form>
                    <header></header>
                    <sheet>
                        <group>
                            <group>
                                <field name="planned_date" readonly="status != 'planned'"/>
                                <field name="visit_date" readonly="status != 'planned'"/>
                                <field name="status"/>
                                <field name="summary"/>
                                <field name="disease_id"/>
                                <field name="active" readonly="status != 'planned'"/>
                            </group>
                            <group>
                                <field name="doctor_id" readonly="status != 'planned'"/>
                                <field name="patient_id"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_hr_hospital_visit_window" model="ir.actions.act_window">
            <field name="name">Visit</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">hr.hospital.visit</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="hr_hospital_menu_item_visit"
                  action="action_hr_hospital_visit_window"
                  parent="hr_hospital_menu_patient"
                  name="Visit" sequence="200"/>
</odoo>